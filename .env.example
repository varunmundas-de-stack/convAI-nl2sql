# Copy this file to .env and fill in your values
# .env is git-ignored

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_ID=claude-sonnet-4-6

# ─── App Auth (JWT) ───────────────────────────────────────────────────────────
APP_JWT_SECRET=change-this-long-random-secret

# ─── Cube.js ──────────────────────────────────────────────────────────────────
# Shared secret between backend (JWT signer) and Cube.js (JWT verifier)
# Must be at least 32 characters; change in production
CUBEJS_API_SECRET=change-this-secret-min-32-chars-long
CUBEJS_URL=http://cubejs:4000
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=cpg_analytics
POSTGRES_USER=cpg_user
POSTGRES_PASSWORD=change-this-strong-password
